{
  "name": "rocketlog",
  "version": "1.0.0",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "test:dev": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watchAll --runInBand",
    "build": "tsup src --out-dir build",
    "start": "node build/server.js",
    "update": "npx npm-check-updates --interactive --format group",
    "prisma:s": "npx prisma studio"
  },
  "license": "ISC",
  "author": "Felipe Mendes",
  "description": "API de entregas de encomendas",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  }
}
